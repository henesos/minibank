<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    MiniBank Checkstyle Configuration
    Based on Google Java Style Guide with project-specific customizations.

    Rules:
    - Import ordering: static -> third party -> java -> javax -> com.minibank
    - Line length max 120
    - Indentation: 4 spaces (no tabs)
    - Method length max 150 lines
    - File length max 500 lines
    - Javadoc required for public classes and public methods
    - Magic number check (meaningful constants required)
    - Empty block / empty statement forbidden
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- File-Level Checks                                              -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- File length max 500 lines -->
    <module name="FileLength">
        <property name="max" value="500"/>
    </module>

    <!-- Line length max 120 characters -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern"
                  value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <!-- No tab characters -->
    <module name="FileTabCharacter"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- TreeWalker (AST-Level Checks)                                  -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <module name="TreeWalker">

        <!-- ─── Indentation: 4 spaces ─── -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="4"/>
            <property name="lineWrappingIndentation" value="4"/>
            <property name="arrayInitIndent" value="4"/>
        </module>

        <!-- ─── Empty Blocks / Statements ─── -->

        <!-- Empty blocks forbidden (TEXT = only comments allowed inside) -->
        <module name="EmptyBlock">
            <property name="option" value="TEXT"/>
            <property name="tokens"
                      value="LITERAL_TRY, LITERAL_FINALLY, LITERAL_IF,
                             LITERAL_ELSE, LITERAL_SWITCH"/>
        </module>

        <!-- Empty catch blocks forbidden (named 'ignored' or 'expected' allowed) -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignore|ignored"/>
        </module>

        <!-- Empty statements forbidden -->
        <module name="EmptyStatement"/>

        <!-- ─── Method Length ─── -->
        <module name="MethodLength">
            <property name="max" value="150"/>
            <property name="countEmpty" value="false"/>
        </module>

        <!-- ─── Javadoc ─── -->

        <!-- Javadoc required for public classes -->
        <module name="MissingJavadocType">
            <property name="scope" value="public"/>
        </module>

        <!-- Javadoc required for public methods -->
        <module name="MissingJavadocMethod">
            <property name="scope" value="public"/>
            <property name="allowedAnnotations" value="Override,Test,BeforeEach,AfterEach,BeforeAll,AfterAll,DisplayName,ParameterizedTest,Nested,TestFactory,TestTemplate,RepeatedTest"/>
        </module>

        <!-- ─── Magic Numbers ─── -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
            <property name="ignoreHashCodeMethod" value="true"/>
            <property name="ignoreAnnotation" value="true"/>
        </module>

        <!-- ─── Import Ordering ─── -->
        <!-- Order: static -> third party -> java.* -> javax.* -> com.minibank.* -->
        <module name="CustomImportOrder">
            <property name="customImportOrderRules"
                      value="STATIC###THIRD_PARTY_PACKAGE###STANDARD_JAVA_PACKAGE###SAME_PACKAGE(2)"/>
            <property name="sortImportsInGroupAlphabetically" value="true"/>
            <property name="separateLineBetweenGroups" value="true"/>
        </module>

        <!-- No wildcard imports -->
        <module name="AvoidStarImport"/>

        <!-- Redundant imports -->
        <module name="RedundantImport"/>

        <!-- Unused imports -->
        <module name="UnusedImports"/>

        <!-- ─── Code Style ─── -->

        <!-- Modifier order: public protected private abstract static final transient volatile synchronized native strictfp -->
        <module name="ModifierOrder"/>

        <!-- Blank line separators -->
        <module name="EmptyLineSeparator">
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
            <property name="tokens"
                      value="PACKAGE_DEF, IMPORT, STATIC_IMPORT, CLASS_DEF,
                             INTERFACE_DEF, ENUM_DEF, STATIC_INIT, INSTANCE_INIT,
                             METHOD_DEF, CTOR_DEF"/>
        </module>

        <!-- Default comes last in switch -->
        <module name="DefaultComesLast"/>

        <!-- Array type style: Java style (String[] args, not String args[]) -->
        <module name="ArrayTypeStyle"/>

        <!-- One top-level class per file -->
        <module name="OneTopLevelClass"/>

        <!-- No trailing whitespace -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\s+$"/>
            <property name="message" value="Trailing whitespace"/>
        </module>

    </module>
</module>
