# ==============================================================
# MiniBank Environment Variables (Template)
# ==============================================================
# Copy this file to .env and set your own values.
# NEVER commit the .env file to version control!
# ==============================================================

# JWT Secret — Must be at least 32 characters.
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-at-least-32-characters-random-string

# Internal Auth Secret — Used for service-to-service authentication.
# Must be different from JWT_SECRET.
# Generate with: openssl rand -base64 48
INTERNAL_AUTH_SECRET=change-me-to-different-32-characters-random-string
